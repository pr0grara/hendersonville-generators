---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import ServiceAreaMap from '@components/ServiceAreaMap.astro';
import FaqSection from '@components/FaqSection.astro';
import FinalCta from '@components/FinalCta.astro';
import QuoteForm from '@components/QuoteForm.astro';
import CityLinks from '@components/CityLinks.astro';
import { SITE, tel } from '@config/site';
import { SERVICES, type Faq } from '@config/services';
import { serviceUrl } from '../lib/urls';
import { defaultHero } from '../lib/images';
import { faqPage } from '../lib/schema';

const title = `${SITE.region} Standby Generator Installation & Service`;
const description = `Standby generator installation, repair, maintenance, and replacement across ${SITE.region}. Automatic backup power for ice-storm outages — keep your well, septic, and heat running. Call ${SITE.phoneDisplay} for a fast quote.`;

// Homepage FAQs (rendered + FAQ schema via FaqSection / faqPage).
const homeFaqs: Faq[] = [
  {
    q: 'What size standby generator does my home need?',
    a: 'It depends on what you want to keep running. A whole-house unit covers everything; a smaller unit can cover the essentials — well pump, septic pump, heat, refrigerator, and key circuits. We do a real load calculation based on your home and recommend a size honestly instead of just selling you the biggest unit.',
  },
  {
    q: 'What generator work do you do?',
    a: 'New standby generator installation, repair (no-start, no-power, error codes), maintenance and service plans, automatic transfer switch installation, and full generator replacement. We work on Generac and comparable brands. One local crew covers it all across Henderson County.',
  },
  {
    q: 'How do I get a quote?',
    a: 'Call us and tell us what you have or what you need — a new install, a unit that won’t start, an old generator to replace, or a maintenance plan. That is usually enough for a straight answer over the phone. You can also send details through the quote form.',
  },
  {
    q: 'Will a generator keep my well and septic pump running?',
    a: 'Yes, when it is sized for them. Many Henderson County homes run on a well and septic pump, so an outage cuts your water and wastewater. We include both pumps in the load calculation so a properly sized unit keeps them running through a storm.',
  },
  {
    q: 'Can you come quickly when my generator fails during an outage?',
    a: 'Generators down during an active outage get priority because of what is at stake — water, wastewater, and heat. Call us with your location and what the unit is doing and we will give you a real time. Call ahead of a forecast storm if you can.',
  },
  {
    q: 'What areas do you cover?',
    a: 'Hendersonville, Fletcher, Mills River, Flat Rock, Laurel Park, Etowah, Edneyville, Dana, Horse Shoe, East Flat Rock, Zirconia, Naples, and the surrounding Henderson County communities. If you are not sure we reach you, call and ask — we likely do.',
  },
];

const jsonLd = faqPage(homeFaqs) ?? [];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <!-- 1. Simple bold headline — no background image, no subtext -->
  <section class="lp-hero">
    <div class="container">
      <h1>Standby Generator Installation & Service in {SITE.region}</h1>
    </div>
  </section>

  <!-- 2. Photo + quote form -->
  <section class="section-sm">
    <div class="container split">
      <div class="lp-photo">
        <Image
          src={defaultHero}
          alt={`Standby generator installation and service in ${SITE.region}`}
          widths={[480, 760, 1000]}
          sizes="(max-width: 920px) 100vw, 560px"
          fetchpriority="high"
          loading="eager"
        />
      </div>
      <QuoteForm source="home-hero" />
    </div>
  </section>

  <!-- 3. Intro / About -->
  <section class="section section-soft" id="about">
    <div class="container prose">
      <h2>Your Local Standby Generator Crew — Install, Repair &amp; Maintain.</h2>
      <p>
        We’re a full-service standby generator company serving {SITE.region} and the surrounding
        mountain communities. A new whole-house generator, a unit that won’t start when the power
        drops, an automatic transfer switch, a maintenance plan, or replacing a tired old
        generator — we handle it all, and we come to your property to do it.
      </p>
      <p>
        Out here the power goes out — ice storms, summer thunderstorms, and trees on rural lines
        knock it down several times a year — and many homes run on a well and septic pump, so an
        outage cuts your water and wastewater too. A properly sized standby generator on propane or
        natural gas brings the whole home back automatically, within seconds, whether you’re home or
        away. Tell us what you have or what you need, and we’ll give you a straight answer and a real
        price.
      </p>
      <ul class="checklist">
        <li>Standby generator installation &amp; whole-house systems</li>
        <li>Generator repair — no-start, no-power &amp; error codes</li>
        <li>Maintenance &amp; service plans, automatic transfer switches</li>
        <li>Generator replacement for tired, out-of-date units</li>
      </ul>
    </div>
  </section>

  <!-- 3. What We Do — a section per service (alternating rows) -->
  <section class="section section-soft" id="services">
    <div class="container">
      <div class="section-head">
        <h2>What We Do</h2>
        <p class="lead muted">
          From a new whole-house install to a unit that won’t start, here’s what we handle for
          {SITE.region} homeowners.
        </p>
      </div>

      {SERVICES.map((s, i) => (
        <div class:list={['srow', { reverse: i % 2 === 1 }]}>
          <div class="srow-media">
            <a href={serviceUrl(s)}>
              <Image
                src={s.image}
                alt={s.imageAlt}
                widths={[480, 720, 960]}
                sizes="(max-width: 920px) 100vw, 500px"
                loading="lazy"
                style="border-radius:var(--radius);width:100%;"
              />
            </a>
          </div>
          <div class="srow-body">
            {s.emergency && <span class="badge">Emergency</span>}
            <h3><a href={serviceUrl(s)}>{s.name}</a></h3>
            <p>{s.description}</p>
            <p class="srow-actions">
              <a class="btn btn-primary" href={serviceUrl(s)}>More on {s.short} →</a>
              <a class="btn btn-call" href={tel()}>Call {SITE.phoneDisplay}</a>
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 4. Service Across Western NC (maps + coverage) -->
  <ServiceAreaMap />

  <!-- 5. Backing up or a soggy yard? — urgency -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>Generator Won’t Start or a Storm Coming? Don’t Wait.</h2>
        <p class="lead muted">
          A standby generator only helps if it runs when you need it. A few situations mean you
          should call today instead of finding out in the dark.
        </p>
      </div>
      <div class="issue-grid">
        <div class="card">
          <h3>It didn’t start when the power dropped</h3>
          <p class="muted">
            A standby unit that fails to start during an outage is an emergency — especially on a
            well-and-septic home with no water or heat. Usually it’s a dead battery, a fuel or
            gas-pressure issue, or a control fault. We diagnose it and get your backup power running.
          </p>
        </div>
        <div class="card">
          <h3>It runs but the house stays dark</h3>
          <p class="muted">
            A generator that starts but won’t power the home usually points to the automatic transfer
            switch or the controls, not the engine. We test the switch, controls, and output to find
            the break in the chain and fix it.
          </p>
        </div>
        <div class="card">
          <h3>A big storm is in the forecast</h3>
          <p class="muted">
            Ahead of an ice or wind storm, don’t gamble on a unit you’re not sure about. We test the
            battery, run a load test, and confirm the generator and transfer switch are ready — so
            you’re not finding out it failed after the lights are already off.
          </p>
        </div>
      </div>
      <p style="text-align:center;margin-top:24px;">
        <a class="btn btn-call btn-lg" href={tel()}>Call {SITE.phoneDisplay}</a>
      </p>
    </div>
  </section>

  <!-- 6. How It Works -->
  <section class="section section-soft">
    <div class="container">
      <div class="section-head">
        <h2>How It Works</h2>
        <p class="lead muted">Three steps, no runaround.</p>
      </div>
      <div class="issue-grid">
        <div class="card">
          <h3>1. Call or request a quote</h3>
          <p class="muted">
            Call {SITE.phoneDisplay} or send the quote form. Tell us where the property is and what’s
            going on and we’ll give you a straight price and a real time.
          </p>
        </div>
        <div class="card">
          <h3>2. Tell us about your home</h3>
          <p class="muted">
            Let us know what you have or what you need — a new install, a unit that won’t start, an
            old generator to replace, or a maintenance plan — and what you want to keep running in an
            outage. That’s usually enough for an honest quote.
          </p>
        </div>
        <div class="card">
          <h3>3. We come to your property</h3>
          <p class="muted">
            We do a real load calculation, install or service the unit on-site, and commission it
            under load before we leave. No upsells, no surprises — just a system you can count on
            when the power drops.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Service area list -->
  <CityLinks
    title={`Service Area — Across ${SITE.region} & the Surrounding Mountains`}
    sub="Standby generator installation, repair, and maintenance for every community we cover."
  />

  <!-- 8. FAQ -->
  <FaqSection faqs={homeFaqs} title="Questions We Hear a Lot" />

  <!-- Final CTA -->
  <FinalCta />
</BaseLayout>

<style>
  .srow-body .badge {
    display: inline-block;
    background: #b42318;
    color: #fff;
    font-size: 11px;
    font-weight: bold;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: var(--radius);
    margin-bottom: 8px;
  }
  .srow-body h3 {
    font-size: 1.35rem;
    margin-bottom: 8px;
  }
  .srow-body h3 a {
    color: var(--navy);
    text-decoration: none;
  }
  .srow-body h3 a:hover {
    color: var(--green-dark);
  }
  .srow-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 4px;
  }
</style>
